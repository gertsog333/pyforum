# Default ignored files
/shelf/
/workspace.xml
/.idea
/venv
/.venv
/.env
env
/*/.env
/.DS_Store
__pycache__/
/FrontEnd/node_modules
__local_settings.py
# migrations tracked in git — do NOT exclude
.coverage

# Vagrant — содержит приватные SSH ключи и состояние VM, не коммитить!
.vagrant/

# Логи
logs/
*.log

# Статика (генерируется автоматически collectstatic, STATIC_ROOT = BASE_DIR)
staticfiles/
/admin/
/css/
/rest_framework/

# Python
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
# Jenkins CI/CD — generated files (contain keys/env, never commit)
jenkins-cicd/jenkins_deploy.pub
jenkins-cicd/.env.jenkins

# Terraform — never commit provider binaries, state, or credentials
**/.terraform/
*.tfstate
*.tfstate.backup
terraform/.terraform.lock.hcl
terraform/bootstrap/.terraform.lock.hcl
terraform/terraform.tfvars
