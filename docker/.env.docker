# =============================================================================
# docker/.env.docker — Environment variables for Docker Compose
#
# This file is used ONLY for local Docker development.
# It is excluded from git via .gitignore.
# DO NOT commit real passwords to version control.
#
# Usage:
#   docker compose --env-file .env.docker up --build
#
# Security note:
#   POSTGRES_PASSWORD and VAULT_DB_PASSWORD must match.
#   VAULT_SECRET_KEY should be a long random string (e.g. 50+ chars).
# =============================================================================

# ---------------------------------------------------------------------------
# PostgreSQL container
# ---------------------------------------------------------------------------
POSTGRES_DB=forum
POSTGRES_USER=forumuser
POSTGRES_PASSWORD=ForumPass123

# ---------------------------------------------------------------------------
# Vault token (dev mode uses a static root token)
# ---------------------------------------------------------------------------
VAULT_TOKEN=root

# ---------------------------------------------------------------------------
# Secrets that vault-init writes into Vault KV v2
# (must match POSTGRES_USER / POSTGRES_PASSWORD above)
# ---------------------------------------------------------------------------
VAULT_DB_NAME=forum
VAULT_DB_USER=forumuser
VAULT_DB_PASSWORD=ForumPass123
VAULT_SECRET_KEY=change-me-use-a-long-random-string-50-chars-minimum-here
VAULT_PGADMIN_EMAIL=admin@example.com
VAULT_PGADMIN_PASSWORD=AdminPass123
VAULT_EMAIL_HOST_USER=your-email@gmail.com
VAULT_EMAIL_HOST_PASSWORD=your-email-app-password

# ---------------------------------------------------------------------------
# Non-secret app config (passed directly to the app container)
# ---------------------------------------------------------------------------
CORS_ORIGIN_WHITELIST=http://localhost:8000
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
