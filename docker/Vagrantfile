# =============================================================================
# docker/Vagrantfile — Single VM with Docker + Docker Compose
#
# Stage 6: Docker deployment on a clean Oracle Linux 9 VM
#
# VM info:
#   Name:  pyforum-docker-host
#   IP:    192.168.56.50
#   RAM:   3 GB
#   CPUs:  2
#
# The project root is mounted into the VM at /home/vagrant/pyforum/
# (Vagrantfile is in docker/, so ".." is the project root)
#
# Usage:
#   cd docker
#   vagrant up
#   vagrant ssh
#   cd /home/vagrant/pyforum/docker
#   docker compose --env-file .env.docker up --build
#
# Access the app at:
#   http://localhost        (HTTP → redirect to HTTPS)
#   https://localhost       (HTTPS, self-signed cert — браузер покажет предупреждение)
#   http://localhost:8200   (Vault UI, token: root)
# =============================================================================

Vagrant.configure("2") do |config|
  config.vm.box = "oraclelinux/9"
  config.vm.box_url = "https://oracle.github.io/vagrant-projects/boxes/oraclelinux/9.json"

  config.vm.define "docker-host" do |docker|
    docker.vm.hostname = "pyforum-docker-host"
    docker.vm.network "private_network", ip: "192.168.56.50"
    docker.vm.network "forwarded_port", guest: 80,   host: 80
    docker.vm.network "forwarded_port", guest: 443,  host: 443
    docker.vm.network "forwarded_port", guest: 8200, host: 8200

    # Mount the project root (one level up from this Vagrantfile)
    docker.vm.synced_folder "..", "/home/vagrant/pyforum"

    docker.vm.provider "virtualbox" do |vb|
      vb.name   = "pyforum-docker-host"
      vb.memory = "3072"
      vb.cpus   = 2
    end

    # Provision: install Docker CE + Docker Compose plugin from official repo
    docker.vm.provision "shell", path: "../DevOps_Scripts/pyforum-provision-docker.sh"

    # Provision: add Jenkins deploy key to vagrant's authorized_keys
    # The key is generated by jenkins-cicd/provision.sh and shared via synced_folder.
    # IMPORTANT: start jenkins-cicd/ VM first, then this VM.
    # If this VM was started first — run `vagrant provision` from docker/ after jenkins VM is up.
    docker.vm.provision "shell", inline: <<-SHELL
      JENKINS_PUBKEY="/home/vagrant/pyforum/jenkins-cicd/jenkins_deploy.pub"
      AUTH_KEYS="/home/vagrant/.ssh/authorized_keys"

      if [ -f "${JENKINS_PUBKEY}" ]; then
        mkdir -p /home/vagrant/.ssh
        chmod 700 /home/vagrant/.ssh
        chown vagrant:vagrant /home/vagrant/.ssh
        if ! grep -qsF "$(cat ${JENKINS_PUBKEY})" "${AUTH_KEYS}" 2>/dev/null; then
          cat "${JENKINS_PUBKEY}" >> "${AUTH_KEYS}"
          chown vagrant:vagrant "${AUTH_KEYS}"
          chmod 600 "${AUTH_KEYS}"
          echo "[provision] Jenkins deploy key added to authorized_keys."
        else
          echo "[provision] Jenkins deploy key already in authorized_keys, skipping."
        fi
      else
        echo "[provision] WARNING: Jenkins pubkey not found at ${JENKINS_PUBKEY}"
        echo "[provision] Start jenkins-cicd/ VM first, then run: vagrant provision"
      fi
    SHELL
  end
end
